# Copia este archivo como `.env.local` y rellena los valores.

# ───── Claude API (opcional, para una futura capa de presentación de
# resultados con LLM; no se usa en el buscador actual) ─────
# Obtén una en https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ───── Claves públicas de los buscadores de cada mutua ─────
# Son identificadores/tokens extraídos de los frontends (no son secretos
# propios), pero los mantenemos fuera del repo para higiene y para que
# GitHub secret scanning no levante alertas. Si alguna env var no está
# definida, el cliente correspondiente devuelve [] en runtime (fail-safe,
# no rompe el resto de fuentes).

# Elastic App Search de Adeslas (engine `cm-pre`). Extraíble del bundle JS
# de `segurcaixaadeslas.es/libraries/sca-cm-cuadromedico/assets/config/env-conf/pro-env.config.json`.
ADESLAS_BEARER=Bearer private-xxxxxxxxxxxxxxxxxxxxxx

# Apikey del cliente MSWeb de Sanitas (`api.sanitas.es`). Visible en
# cualquier petición del cuadro médico público.
SANITAS_APIKEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Hash público que identifica la red Allianz dentro de la plataforma Asisa
# que hostea `buscador.allianzsalud.es` (primer segmento de los paths).
ALLIANZ_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Id del portlet Liferay del buscador de AXA (`axa.es/cuadro-medico-salud`).
# Visible en el HTML (`data-name="_<PORTLET_ID>_*"`). Cambia poco.
AXA_PORTLET_ID=publicportals_HealthSearcherPortlet_INSTANCE_xxxxxxxxxxxxxxx
